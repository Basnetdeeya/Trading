# ─── Core ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_TOKEN=change-me-in-prod
AUTH_ENABLED=false

# ─── Trading mode ────────────────────────────────────────────────────────
# paper | simulation | live
TRADING_MODE=paper
# Must be set to the literal string below to enable live trading
LIVE_TRADING_CONFIRMED=NO

# ─── Capital & risk defaults (user can override in the UI) ───────────────
STARTING_CAPITAL_USD=10000
MAX_POSITION_PCT=0.05          # max 5% of equity per position
MAX_DAILY_LOSS_PCT=0.02        # halt after -2% equity in a day
MAX_DRAWDOWN_PCT=0.15          # halt after -15% equity peak-to-trough
MAX_OPEN_POSITIONS=8
MAX_CORRELATION=0.85           # diversification cap
USE_KELLY=false
DEFAULT_STOP_LOSS_PCT=0.02
DEFAULT_TAKE_PROFIT_PCT=0.04

# ─── Data providers (all optional; free tiers work) ──────────────────────
COINGECKO_API_KEY=
ALPHA_VANTAGE_API_KEY=
YAHOO_FINANCE_ENABLED=true
BINANCE_API_KEY=
BINANCE_API_SECRET=
POLYMARKET_API_URL=

# ─── AI agent (optional) ─────────────────────────────────────────────────
# If both are empty, the heuristic fallback agent is used.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Database ────────────────────────────────────────────────────────────
# Use Postgres URL in prod, SQLite by default
DATABASE_URL=sqlite:///./quant_sentinel.db

# ─── Frontend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
